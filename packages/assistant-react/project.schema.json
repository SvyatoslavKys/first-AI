{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://first-ai.dev/schemas/assistant-project.schema.json",
  "title": "First AI Assistant Project",
  "description": "Public project knowledge passed to the First AI React component.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "type",
    "description",
    "purpose",
    "capabilities",
    "goals",
    "services",
    "faq",
    "pages",
    "contacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{1,64}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "type": {
      "enum": ["website", "web-app", "mobile-app", "service", "other"]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "targetAudience": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "capabilities": {
      "$ref": "#/$defs/shortTextList"
    },
    "goals": {
      "$ref": "#/$defs/shortTextList"
    },
    "services": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/service"
      }
    },
    "faq": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/faqItem"
      }
    },
    "pages": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/page"
      }
    },
    "contacts": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/contact"
      }
    },
    "assistantRules": {
      "$ref": "#/$defs/shortTextList"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9-]{1,64}$"
    },
    "projectUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(https?://|/(?!/))"
    },
    "shortTextList": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "price": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency"],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "from": {
          "type": "number",
          "minimum": 0
        },
        "to": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "minLength": 1,
          "maxLength": 12
        },
        "unit": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "note": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1200
        },
        "price": {
          "$ref": "#/$defs/price"
        },
        "deliveryTime": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "orderUrl": {
          "$ref": "#/$defs/projectUrl"
        }
      }
    },
    "faqItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "answer"],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "answer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "url"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "url": {
          "$ref": "#/$defs/projectUrl"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "enum": ["email", "phone", "telegram", "url", "other"]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        }
      }
    }
  }
}
