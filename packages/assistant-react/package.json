{
  "name": "@first-ai/assistant-react",
  "version": "0.1.0",
  "description": "A reusable React chat widget with props-first project context, localization, theming, and structured conversation events.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "files": [
    "dist",
    "project.schema.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "development": "./src/styles.css",
      "default": "./dist/styles.css"
    },
    "./project.schema.json": "./project.schema.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "node test/run.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
