{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "first-ai-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-21",
  "vars": {
    "ALLOWED_ORIGINS": "http://localhost:5173",
    "AI_ROUTES": "groq:openai/gpt-oss-120b,groq:openai/gpt-oss-20b,gemini:gemini-3.5-flash,workers-ai:@cf/zai-org/glm-4.7-flash,mock:local",
    "PROVIDER_TIMEOUT_MS": "20000"
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
}
